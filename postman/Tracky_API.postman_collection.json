    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Signin",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "pm.environment.set(\"token\", jsonData.token);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"admin@tracky.com\",\n    \"password\": \"admin123!@#\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/signin",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "signin"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
